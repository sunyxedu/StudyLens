APP_ENV=local
DATA_DIR=data
DATABASE_URL=sqlite:///data/studylens.db
VECTOR_STORE=qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=data/vector/qdrant
QDRANT_COLLECTION=studylens_chunks
VECTOR_DB_PATH=data/vector/studylens.sqlite3
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TURNS=80
IMPERIAL_USERNAME=
IMPERIAL_PASSWORD=
BROWSER_STORAGE_STATE=
AUTH_SECRET_KEY=
SESSION_COOKIE_NAME=studylens_session
SESSION_COOKIE_SECURE=
# Blank = lax (correct when the app is served same-origin at /app). Only set to
# none for a cross-site split deploy, which additionally requires Secure.
SESSION_COOKIE_SAMESITE=
SESSION_TTL_DAYS=14
# Override the built web frontend served at /app. Docker sets this; leave blank
# for editable/dev runs (falls back to the in-repo web/dist).
STUDYLENS_WEB_DIST=
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,chrome-extension://*
